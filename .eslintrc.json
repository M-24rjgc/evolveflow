{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "project": true
  },
  "plugins": ["@typescript-eslint"],
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended"],
  "env": {
    "node": true,
    "es2022": true
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "target",
    "apps/desktop-tauri/src-tauri/gen",
    "*.js",
    "*.d.ts",
    "packages/evolveflow-vendor-pi-agent",
    "packages/evolveflow-vendor-pi-ai"
  ],
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/explicit-function-return-type": "off",
    "no-console": "warn",
    "no-debugger": "error",
    "eqeqeq": ["error", "always"],
    "curly": "error",
    "prefer-const": "error",
    "no-var": "error"
  },
  "overrides": [
    {
      "files": ["packages/evolveflow-runtime/src/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["**/tests/**/*.ts", "**/*.test.ts", "**/*.spec.ts"],
      "parserOptions": {
        "project": false
      },
      "rules": {
        "no-console": "off",
        "@typescript-eslint/no-explicit-any": "off"
      }
    },
    {
      "files": [
        "**/bench/**/*.ts",
        "**/*.config.ts",
        "**/*.setup.ts",
        "**/vitest.config.ts",
        "vitest.workspace.ts",
        "apps/desktop-tauri/e2e/**/*.ts",
        "apps/desktop-tauri/playwright.config.ts"
      ],
      "parserOptions": {
        "project": false
      },
      "env": {
        "browser": true,
        "node": true
      }
    },
    {
      "files": ["apps/desktop-tauri/src/**/*.ts", "apps/desktop-tauri/src/**/*.tsx"],
      "env": {
        "browser": true,
        "node": true
      }
    }
  ]
}
