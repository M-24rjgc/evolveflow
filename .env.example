# EvolveFlow 环境变量配置
# 复制此文件为 .env 并填入真实的密钥值
# .env 文件已被 .gitignore 排除，不会被提交到 Git

# AI Provider: deepseek 或 anthropic
EVOLVEFLOW_AI_PROVIDER=deepseek

# DeepSeek API Key (从 https://platform.deepseek.com/api_keys 获取)
EVOLVEFLOW_AI_KEY=your-deepseek-api-key-here

# DeepSeek 模型 (默认: deepseek-v4-flash)
EVOLVEFLOW_AI_MODEL=deepseek-v4-flash

# 可选: Anthropic API Key (仅在使用 anthropic provider 时需要)
# EVOLVEFLOW_AI_PROVIDER=anthropic
# EVOLVEFLOW_AI_KEY=your-anthropic-api-key-here
# EVOLVEFLOW_AI_MODEL=claude-sonnet-4-20250514

# Sentry DSN (optional - from https://sentry.io)
# EVOLVEFLOW_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
