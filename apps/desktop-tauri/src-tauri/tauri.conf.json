{
  "productName": "EvolveFlow",
  "version": "0.1.0",
  "identifier": "com.evolveflow.desktop",
  "build": {
    "beforeDevCommand": "npm run build -w @evolveflow/runtime && npm run prepare:resources && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build -w @evolveflow/storage && npm run build -w @evolveflow/domain && npm run build -w @evolveflow/capabilities && npm run build -w @evolveflow/runtime && npm run prepare:resources && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EvolveFlow - 智能日程助手",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": ["https://github.com/m-24rjgc/evolveflow/releases/latest/download/latest.json"],
      "dialog": true,
      "pubkey": "PLACEHOLDER_GENERATE_WITH_TAURI_SIGNER"
    }
  }
}
